00010 ' ====================================
00020 ' ALIEMINATION
00030 ' MANOEL NETO 2025
00040 ' ====================================
00050 COLOR 15,1,1
00060 KEY OFF:CLS:DEFINT A-Z
00070 BLOAD"XBASIC.BIN",R
00080 DEFUSR1=&H41 : ' FUNCAO DESLIGA TELA
00090 DEFUSR2=&H44 : ' FUNCAO LIGA TELA

00100 ' ====================================
00110 ' SPLASH SCREEN
00120 ' ====================================
00130 SCREEN 1,2
00140 LOCATE 6,8:? "SPACE INVADERS"
00150 LOCATE 4,9:? "PRESS FIRE TO START"
00160 LOCATE 6,10:? "MANOEL NETO 2024"
00170 OP$=INPUT$(1)
00180 CLS

00200 ' ====================================
00210 ' INICIALIZA JOGO
00220 ' ====================================
00230 DIM EX(5,11),EY(5,11)
00240 AL=1:CA=2:LA=1:DR=1:' ALIENS
00250 TC=0:TX=0:TY=0:' TORPEDO
00260 CC=0: ' CONTADOR DE COLUNAS
00270 HX=127: HY=174: HV=16 : ' X E Y DO HEROI
00280 GOSUB 6000 : ' CARREGA TABELA DE PADROES
00290 GOSUB 7000 : ' CARREGA TABELA DE CORES
00300 GOSUB 8000 : ' CARREGA TABELA DE SPRITES
00310 ' ======= POSICIONA OS ALIENS =======
00320 FOR I = 0 TO 4
00330    FOR J = 0 TO 10
00340        EX(I,J)=(J+1)*CA
00350        EY(I,J)=LA+I
00360    NEXT J
00370 NEXT I
00380 CALL TURBO ON (EX(),EY(),HX,HY,HV,TC,TX,TY,CC)

00500 ' ======= METODO UPDATE =========
00510 IF CC=7 THEN DR=-1:LA=LA+1
00520 IF CC=0 THEN DR=1:LA=LA+1
00530 IF LA>=20 THEN 5000
00540 IF TC=1 THEN 3000
00550 IF STRIG(0)=-1 GOTO 2000 
00560 JS=STICK(0)  
00570 IF JS = 3 THEN GOTO 600
00580 IF JS = 7 THEN GOTO 610
00590 GOTO 620 
00600 HX=HX+HV:GOTO 620
00610 HX=HX-HV
00620 IF HX<0 THEN HX=0
00630 IF HX>239 THEN HX=239
00640 IF TC=1 THEN TY = TY-16
00650 IF AL=2 THEN AL=1 ELSE AL=2 
00660 CC=CC+DR
00670 ' ============ METODO DRAW ===========
00680 A=USR1(0) 
00690 FOR I = 0 TO 4
00700    FOR J = 0 TO 10
00710      CL=EX(I,J):LN=EY(I,J)
00720       VPOKE &H1800+CL+LN*32,0
00730       CL=CL+DR
00740       LN=LA+I
00750       VPOKE &H1800+CL+LN*32,AL
00760       EX(I,J)=CL
00770       EY(I,J)=LN
00780    NEXT J
00790 NEXT I
00800 PUT SPRITE 0,(HX,HY),6,0 : 'CANHAO
00810 IF TC=1 THEN PUT SPRITE 1,(TX,TY),8,1 : 'TORPEDO
00820 A=USR2(1) 
00830 ' ========== FRAME ==========
00840 TIME = 0 
00850 IF TIME<60 THEN 850
00860 GOTO 500

02000 ' ====================================
02010 ' TORPEDO
02020 ' ====================================
02030 IF TC = 1 THEN GOTO 560
02040 TC=1:TX=HX:TY=HY-10
02050 GOTO 560

03000 ' === VERIFICA COLISAO COM ALIENS ====
03010 IF TY<0 THEN TC=0:GOTO 550
03020 FOR CI=0 TO 4
03030    FOR CJ=0 TO 10
03035       LOCATE 1,20:? "C1:";:?ABS(EX(CI,CJ)-TX);:?" C2:";:?ABS(EY(CI,CJ)-TY); 
03040       IF ABS(EX(CI,CJ)-TX)<16 AND ABS(EY(CI,CJ)-TY)<8 THEN TC=0:EX(CI,CJ)=-100:EY(CI,CJ)=-100
03045       INPUT OP$
03050    NEXT CJ
03060 NEXT CI
03070 GOTO 560

05000 CALL TURBO OFF
05010 ' ====================================
05020 ' FIM DO JOGO
05030 ' ====================================
05040 CLS
05050 LOCATE 6,8:? "GAME OVER"
05060 LOCATE 4,9:? "PRESS FIRE TO PLAY AGAIN"
05070 OP$=INPUT$(1)
05080 GOTO 100

06000 ' ====================================
06010 ' CARREGA A TABELA DE PADROES 
06020 ' ====================================
06030 RESTORE 9000
06040 S=0 
06050 READ R$
06060 IF R$="*" THEN RETURN ELSE VPOKE S,VAL("&H"+R$):S=S+1
06070 GOTO 6050

07000 ' ====================================
07010 ' CARREGA A TABELA DE CORES  
07020 ' ====================================
07030 FOR I=0 TO 31
07040   VPOKE &H2000+I,32
07050 NEXT I
07060 RETURN 

08000 ' ====================================
08010 ' CARREGA TABELA DE PADROES DE SPRITES
08020 ' ====================================
08030 RESTORE 10000
08040 S=BASE(9)
08050 READ R$
08060 IF R$="*" THEN RETURN ELSE VPOKE S,VAL("&H"+R$):S=S+1
08070 GOTO 8050

09000 ' ====================================
09010 ' SOFT SPRITES           
09020 ' ====================================
09030 ' ALIENS - COLOR 7
09040 DATA 00,00,00,00,00,00,00,00
09050 DATA 18,3C,7E,DB,FF,24,5A,A5
09060 DATA 18,3C,7E,DB,FF,5A,81,42
09070 DATA *

10000 ' ====================================
10010 ' HARD SPRITES
10020 ' ====================================
10030 ' CANHAO - COLOR 6
10040 DATA 00,00,00,00,00,00,00,00
10050 DATA 01,01,07,07,1F,1F,7F,7F
10060 DATA 00,00,00,00,00,00,00,00
10070 DATA 80,80,E0,E0,F8,F8,FE,FE
10080 ' TORPEDO - COLOR 8
10090 DATA 00,00,00,00,00,00,00,00
10100 DATA 00,01,01,01,01,01,01,01
10110 DATA 00,00,00,00,00,00,00,00
10120 DATA 00,80,80,80,80,80,80,80
10130 DATA *