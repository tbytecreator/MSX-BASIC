00010 ' ====================================
00020 ' ALIEMINATION
00030 ' MANOEL NETO 2026
00040 ' ====================================
00050 COLOR 15,1,1
00060 KEY OFF:CLS:DEFINT A-Z
00070 BLOAD"XBASIC.BIN",R
00080 DEFUSR1=&H41 : ' FUNCAO DESLIGA TELA
00090 DEFUSR2=&H44 : ' FUNCAO LIGA TELA

00100 ' ======== SPLASH SCREEN    ==========
00110 SCREEN 1,2
00120 LOCATE 6,8:? "SPACE INVADERS"
00130 LOCATE 4,9:? "PRESS FIRE TO START"
00140 LOCATE 6,10:? "MANOEL NETO 2026"
00150 OP$=INPUT$(1)
00160 CLS

00200 ' ======== INICIALIZA JOGO ===========
00210 DIM EX(5,11),EY(5,11)
00220 AL=1:CA=2:LA=1:DR=1
00230 TC=0:TX=0:TY=0:CC=0
00240 HX=127:HY=174:HV=16 
00250 GOSUB 6000 : ' TABELA DE PADROES
00260 GOSUB 7000 : ' TABELA DE CORES
00270 GOSUB 8000 : ' TABELA DE SPRITES
00280 ' ======= POSICIONA OS ALIENS =======
00290 FOR I = 0 TO 4
00300    FOR J = 0 TO 10
00310        EX(I,J)=(J+1)*CA
00320        EY(I,J)=LA+I
00330    NEXT J
00340 NEXT I
00350 ON STRIG GOSUB 2000: ' DISPARO
00360 STRIG(0) ON

00500 ' ======= METODO UPDATE =========
00510 CALL TURBO ON (EX(),EY(),HX,HY,HV,TC,TX,TY,CC)
00520 IF CC=7 THEN DR=-1:LA=LA+1
00530 IF CC=0 THEN DR=1:LA=LA+1
00540 IF LA>=20 THEN 5000
00550 IF TC=1 THEN 1000
00560 JS=STICK(0)  
00570 IF JS = 3 THEN 600
00580 IF JS = 7 THEN 610
00590 GOTO 620 
00600 HX=HX+HV:GOTO 620
00610 HX=HX-HV
00620 IF HX<0 THEN HX=0
00630 IF HX>239 THEN HX=239
00640 IF TC=1 THEN TY = TY-16
00650 IF AL=2 THEN AL=1 ELSE AL=2 
00660 CC=CC+DR
00670 ' ============ METODO DRAW ===========
00680 A=USR1(0) 
00690 FOR I = 0 TO 4
00700    FOR J = 0 TO 10
00710       CL=EX(I,J):LN=EY(I,J)
00720       VPOKE &H1800+CL+LN*32,0
00730       CL=CL+DR
00740       LN=LA+I
00750       VPOKE &H1800+CL+LN*32,AL
00760       EX(I,J)=CL
00770       EY(I,J)=LN
00780    NEXT J
00790 NEXT I
00800 IF TC=1 THEN VPOKE &H1800+TX+TY*32,3 : 'TORPEDO
00810 PUT SPRITE 0,(HX,HY),6,0 : 'CANHAO
00820 A=USR2(1)
00840 ' ========== FRAME ==========
00850 'TIME = 0 
00860 IF TIME<60 THEN 850
00870 GOTO 520

01000 ' === VERIFICA COLISAO COM ALIENS ====
01010 IF TY<0 THEN TC=0:GOTO 560
01020 FOR CI=0 TO 4
01030    FOR CJ=0 TO 10
01035       LOCATE 1,20:? "C1:";:?ABS(EX(CI,CJ)-TX);:?" C2:";:?ABS(EY(CI,CJ)-TY); 
01040       IF ABS(EX(CI,CJ)-TX)<16 AND ABS(EY(CI,CJ)-TY)<8 THEN TC=0:EX(CI,CJ)=-100:EY(CI,CJ)=-100
01050       INPUT OP$
01060    NEXT CJ
01070 NEXT CI
01080 GOTO 560

01090 CALL TURBO OFF 

02000 ' ======== ADICIONA TORPEDO =========
02010 IF TC = 1 THEN RETURN
02020 TC=1:TX=HX:TY=HY-10
02030 RETURN

05010 ' ====================================
05020 ' FIM DO JOGO
05030 ' ====================================
05040 CLS
05050 LOCATE 6,8:? "GAME OVER"
05060 LOCATE 4,9:? "PRESS FIRE TO PLAY AGAIN"
05070 OP$=INPUT$(1)
05080 GOTO 100

06000 ' ====================================
06010 ' CARREGA A TABELA DE PADROES 
06020 ' ====================================
06030 RESTORE 9000
06040 S=0 
06050 READ R$
06060 IF R$="*" THEN RETURN ELSE VPOKE S,VAL("&H"+R$):S=S+1
06070 GOTO 6050

07000 ' ====================================
07010 ' CARREGA A TABELA DE CORES  
07020 ' ====================================
07030 FOR I=0 TO 31
07040   VPOKE &H2000+I,32
07050 NEXT I
07060 RETURN 

08000 ' ====================================
08010 ' CARREGA TABELA DE PADROES DE SPRITES
08020 ' ====================================
08030 RESTORE 10000
08040 S=BASE(9)
08050 READ R$
08060 IF R$="*" THEN RETURN ELSE VPOKE S,VAL("&H"+R$):S=S+1
08070 GOTO 8050

09000 ' ====================================
09010 ' SOFT SPRITES           
09020 ' ====================================
09030 ' ALIENS - COLOR 7
09040 DATA 00,00,00,00,00,00,00,00
09050 DATA 18,3C,7E,DB,FF,24,5A,A5
09060 DATA 18,3C,7E,DB,FF,5A,81,42
09070 ' TORPEDO - COLOR 8
09080 DATA 00,00,18,18,18,18,00,00
09090 DATA *

10000 ' ====================================
10010 ' HARD SPRITES
10020 ' ====================================
10030 ' CANHAO - COLOR 6
10040 DATA 00,00,00,00,00,00,00,00
10050 DATA 01,01,07,07,1F,1F,7F,7F
10060 DATA 00,00,00,00,00,00,00,00
10070 DATA 80,80,E0,E0,F8,F8,FE,FE
10130 DATA *